{
  "name": "@goable-io/profiles-catalog",
  "version": "2.3.1",
  "description": "Open catalog of outdoor activity profiles (water, snow, air, land) that define how weather inputs combine into a 0-100 suitability score. CC BY 4.0.",
  "license": "CC-BY-4.0",
  "author": "Fabio Carucci <contact@fabio-carucci.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goable-io/profiles-catalog.git"
  },
  "bugs": {
    "url": "https://github.com/goable-io/profiles-catalog/issues"
  },
  "homepage": "https://github.com/goable-io/profiles-catalog#readme",
  "keywords": [
    "outdoor",
    "activities",
    "weather",
    "scoring",
    "kitesurf",
    "ski",
    "paragliding",
    "climatology",
    "sport-science",
    "open-data"
  ],
  "type": "module",
  "main": "./dist/schema/index.js",
  "types": "./dist/schema/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    },
    "./stats": {
      "types": "./dist/schema/stats.d.ts",
      "import": "./dist/schema/stats.js"
    },
    "./catalog.json": "./dist/catalog.json",
    "./profile.schema.json": "./dist/profile.schema.json",
    "./catalog-stats.json": "./dist/catalog-stats.json",
    "./package.json": "./package.json"
  },
  "files": [
    "catalog",
    "dist",
    "schema",
    "LICENSE",
    "CITATION.cff",
    "README.md"
  ],
  "scripts": {
    "validate": "tsx schema/validate.ts",
    "build": "tsc -p tsconfig.build.json",
    "bundle": "tsx scripts/bundle-for-npm.ts && tsx scripts/emit-json-schema.ts && tsx scripts/compute-stats.ts",
    "list-profiles": "tsx scripts/list-profiles.ts",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm validate && pnpm typecheck && pnpm test && pnpm build && pnpm bundle"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "glob": "^11.0.0",
    "tsx": "^4.22.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "yaml": "^2.7.0"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f"
}
