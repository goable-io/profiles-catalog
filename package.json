{
  "name": "@goable-io/profiles-catalog",
  "version": "1.0.0",
  "description": "Open catalog of outdoor activity profiles (water, snow, air, land) that define how weather inputs combine into a 0-100 suitability score. CC BY 4.0.",
  "license": "CC-BY-4.0",
  "author": "Fabio Carucci <contact@fabio-carucci.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goable-io/profiles-catalog.git"
  },
  "bugs": {
    "url": "https://github.com/goable-io/profiles-catalog/issues"
  },
  "homepage": "https://github.com/goable-io/profiles-catalog#readme",
  "keywords": [
    "outdoor", "activities", "weather", "scoring",
    "kitesurf", "ski", "paragliding", "climatology",
    "sport-science", "open-data"
  ],
  "type": "module",
  "files": ["catalog", "dist", "schema", "LICENSE", "CITATION.cff", "README.md"],
  "scripts": {
    "validate": "tsx schema/validate.ts",
    "bundle": "tsx scripts/bundle-for-npm.ts",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "glob": "^11.0.0",
    "tsx": "^4.22.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "yaml": "^2.7.0",
    "zod": "^4.0.0"
  },
  "engines": { "node": ">=20" },
  "publishConfig": { "access": "public" }
}
